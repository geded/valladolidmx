{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valladolid.mx/schemas/product-authorization.schema.json",
  "title": "Valladolid.mx Product Change Authorization",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "status", "branch", "blueprint", "founder_authority", "permissions", "public_routes", "required_feature_flags", "required_tests"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^PCA-[A-Z0-9][A-Z0-9._-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["Draft", "Approved", "Consumed", "Revoked"] },
    "branch": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]+$" },
    "blueprint": { "type": "string", "pattern": "^docs/blueprint/.+\\.md$" },
    "founder_authority": { "type": "string", "minLength": 12 },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation", "path"],
        "properties": {
          "operation": { "enum": ["create", "modify", "delete", "rename"] },
          "path": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 }
        }
      }
    },
    "public_routes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "required_feature_flags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "required_tests": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
